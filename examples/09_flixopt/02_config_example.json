{
    "name": "mpc_flixopt_example_02",
    "interfaces": {
        "mqtt": false,
        "fiware": false,
        "file": true
    },
    "inputs": [
        {
            "id": "flixopt_input_entity",
            "interface": "file",
            "attributes": [
                {
                    "id": "electricity_demand",
                    "id_interface": "flixopt_input_entity.electricity_demand",
                    "type": "timeseries"
                },
                {
                    "id": "heat_demand",
                    "id_interface": "flixopt_input_entity.heat_demand",
                    "type": "timeseries"
                },
                {
                    "id": "electricity_price",
                    "id_interface": "flixopt_input_entity.electricity_price",
                    "type": "timeseries"
                }
            ]
        }
    ],
    "outputs": [
    ],
    "staticdata": [
        {
            "id": "flixopt_input_test",
            "interface": "file",
            "attributes": [
                {
                    "id": "storage_level",
                    "id_interface": "storage_level",
                    "type": "value"
                }
            ]
        }
    ],
    "controller_components": [
        {
            "id": "flixopt_model_component",
            "type": "flixopt_model_component",
            "inputs": {
                "heat_demand": {
                    "entity": "flixopt_input_entity",
                    "attribute": "heat_demand"
                },
                "electricity_demand": {
                    "entity": "flixopt_input_entity",
                    "attribute": "electricity_demand"
                },
                "electricity_price": {
                    "entity": "flixopt_input_entity",
                    "attribute": "electricity_price"
                },
                "storage_level": {
                    "entity": "flixopt_input_test",
                    "attribute": "storage_level"
                }
            },
            "outputs": {

            },
            "config": {
                "log_level": {
                    "value": "debug"
                },
                "solver_settings": {
                    "value": {
                        "name": "HighsSolver",
                        "mip_rel_gap": 0.01,
                        "time_limit": 60
                    }
                },
                "flixopt_model": {
                    "value": "02_flixopt_model_config.json"
                }
            }
        }
    ],
    "controller_settings": {
        "time_settings": {
            "calculation": {
                "timerange": 1,
                "timerange_unit": "hour",
                "sampling_time": 60,
                "sampling_time_unit": "second",
                "timestep": 1,
                "timestep_unit": "hour"
            }
        }
    }
}